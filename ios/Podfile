# Flutter iOS Podfile
# Run `pod install` from the ios/ directory after cloning on macOS.

platform :ios, '16.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug'   => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(
    File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. " \
          "Run `flutter pub get` first."
  end
  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}."
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin',
                                   'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  # Static linkage: all CocoaPods pods are compiled into the Runner binary directly.
  # This avoids separate .framework files for each pod, which sideloading tools
  # (iLoader, Sideloadly, etc.) may fail to re-sign — causing a silent SIGKILL on launch.
  # Flutter.framework and App.framework are still dynamic (managed by Flutter, not CocoaPods).
  use_frameworks! :linkage => :static
  use_modular_headers!

  # Flutter plugins
  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))

  # iCamera native C++ image processing pipeline (statically linked into Runner binary)
  pod 'NativeProcessor', :path => '.'
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '16.0'
      config.build_settings['ENABLE_BITCODE'] = 'NO'
      # Restrict permission_handler_apple to only the permissions iCamera uses.
      # Without this, it compiles ALL permission handlers and may link entitlement-gated
      # frameworks (HomeKit, Health, etc.) that crash sideloaded builds.
      if target.name == 'permission_handler_apple'
        config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= [
          '$(inherited)',
          'PERMISSION_CAMERA=1',
          'PERMISSION_PHOTOS=1',
          'PERMISSION_MICROPHONE=1',
        ]
      end
    end
  end
end
